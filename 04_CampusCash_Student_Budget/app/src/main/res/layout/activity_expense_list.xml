<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Expense List"
            android:textColor="@color/text_dark"
            android:textSize="30sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clean money control, same engine, new skin"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
        <EditText
            android:id="@+id/edtExpenseStartDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:hint="Start Date YYYY-MM-DD"
            android:padding="14dp" />
        <EditText
            android:id="@+id/edtExpenseEndDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:hint="End Date YYYY-MM-DD"
            android:padding="14dp" />
        <Button
            android:id="@+id/btnLoadExpenses"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Load Expenses" />
        <ListView
            android:id="@+id/listExpenses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:divider="@color/blue_light"
            android:dividerHeight="1dp" />
    </LinearLayout>
</ScrollView>
