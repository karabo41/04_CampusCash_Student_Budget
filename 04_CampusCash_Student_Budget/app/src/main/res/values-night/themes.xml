<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartBudget" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_color</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:navigationBarColor">@color/blue_dark</item>
        <item name="android:statusBarColor">@color/blue_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialButtonStyle">@style/AppButton</item>
    </style>

    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
    </style>
</resources>
